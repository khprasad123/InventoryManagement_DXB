// Prisma schema for KaHa Enterprise Cloud (SaaS Multi-Tenant)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  CLOSED
}

enum SalesInvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// =============================================================================
// CORE: ORGANIZATION (TENANT) & AUTH
// =============================================================================

model Organization {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  logoUrl  String?   @map("logo_url")
  phone    String?
  fax      String?
  website  String?
  timezone String?   @default("UTC") @map("timezone") // IANA timezone for display
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  invoiceSettings InvoiceSettings?
  orgPlan         OrgPlan?
  users           UserOrganization[]
  roles             Role[]
  currencies        Currency[]
  items             Item[]
  suppliers         Supplier[]
  clients           Client[]
  stockMovements    StockMovement[]
  grns              Grn[]
  purchaseInvoices  PurchaseInvoice[]
  purchaseRequests  PurchaseRequest[]
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]
  salesInvoices     SalesInvoice[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  supplierPayments  SupplierPayment[]
  clientPayments    ClientPayment[]
  documents         Document[]
  reportExports     ReportExport[]
  dashboardPreferences UserDashboardPreference[]
  glAccounts        GlAccount[]
  journalEntries    JournalEntry[]
  bankAccounts      BankAccount[]
  bankStatements    BankStatement[]
  bankTransactions   BankTransaction[]
  bankReconciliations BankReconciliation[]
  auditLogs         AuditLog[]

  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

model InvoiceSettings {
  id               String   @id @default(cuid())
  organizationId   String   @unique @map("organization_id")
  companyName      String   @map("company_name")
  address          String?
  phone            String?
  fax              String?
  website          String?
  taxRegistrationNo String? @map("tax_registration_no")
  bankDetails      String?  @map("bank_details")
  defaultTaxPercent Decimal @default(5) @map("default_tax_percent") @db.Decimal(5, 2) // VAT % for invoices/quotations (per document stored)
  invoiceLogoUrl   String?  @map("invoice_logo_url")
  sealUrl          String?  @map("seal_url") // Stamp - optional
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoice_settings")
}

model OrgPlan {
  id                String    @id @default(cuid())
  organizationId    String    @unique @map("organization_id")
  monthlyAmount     Decimal   @map("monthly_amount") @db.Decimal(12, 2)
  maxUsers          Int       @map("max_users") // Excluding super admin
  contractStartDate DateTime  @map("contract_start_date")
  contractEndDate   DateTime? @map("contract_end_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_plans")
}

model Currency {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  code           String
  name           String
  symbol         String?   @map("symbol")
  isDefault      Boolean   @default(false) @map("is_default")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("currencies")
}

model Role {
  id             String    @id @default(cuid())
  name           String // ADMIN, INVENTORY, FINANCE, SALES or custom
  organizationId String?   @map("organization_id") // null = system-wide role
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  organization      Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userOrganizations UserOrganization[]
  permissions       RolePermission[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. manage_users, record_payments
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([deletedAt])
  @@map("role_permissions")
}

model User {
  id            String    @id @default(cuid())
  email         String
  passwordHash  String    @map("password_hash")
  name          String?
  signatureUrl String?   @map("signature_url")
  emailVerified DateTime? @map("email_verified")
  sessionToken  String?   @map("session_token") // For single-session: invalidates other logins
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")

  organizations            UserOrganization[]
  auditLogs                AuditLog[]
  createdItems             Item[]             @relation("ItemCreatedBy")
  updatedItems             Item[]             @relation("ItemUpdatedBy")
  createdSuppliers         Supplier[]         @relation("SupplierCreatedBy")
  updatedSuppliers         Supplier[]         @relation("SupplierUpdatedBy")
  createdClients           Client[]           @relation("ClientCreatedBy")
  updatedClients           Client[]           @relation("ClientUpdatedBy")
  createdPurchaseInvoices  PurchaseInvoice[]  @relation("PurchaseInvoiceCreatedBy")
  updatedPurchaseInvoices  PurchaseInvoice[]  @relation("PurchaseInvoiceUpdatedBy")
  createdSalesInvoices     SalesInvoice[]     @relation("SalesInvoiceCreatedBy")
  updatedSalesInvoices     SalesInvoice[]     @relation("SalesInvoiceUpdatedBy")
  approvedSalesInvoices    SalesInvoice[]     @relation("SalesInvoiceApprovedBy")
  createdQuotations        Quotation[]        @relation("QuotationCreatedBy")
  updatedQuotations        Quotation[]        @relation("QuotationUpdatedBy")
  createdExpenses          Expense[]          @relation("ExpenseCreatedBy")
  updatedExpenses          Expense[]          @relation("ExpenseUpdatedBy")
  createdDocuments         Document[]         @relation("DocumentCreatedBy")
  updatedDocuments         Document[]         @relation("DocumentUpdatedBy")
  generatedReportExports   ReportExport[]     @relation("ReportExportGeneratedBy")
  dashboardPreferences     UserDashboardPreference[]

  @@unique([email])
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model UserDashboardPreference {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  widgetIds      Json     @default("[]") @map("widget_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("user_dashboard_preferences")
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  roleId         String   @map("role_id")
  isSuperAdmin   Boolean  @default(false) @map("is_super_admin") // org super admin; only they can edit/remove other super admins
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("user_organizations")
}

// =============================================================================
// INVENTORY
// =============================================================================

model Item {
  id                    String    @id @default(cuid())
  organizationId        String    @map("organization_id")
  sku                   String
  name                  String
  description           String?
  category              String?   @default("General")
  unit                  String    @default("pcs")
  defaultPurchaseCost   Decimal   @default(0) @map("default_purchase_cost") @db.Decimal(12, 2)
  defaultMargin         Decimal   @default(0) @map("default_margin") @db.Decimal(5, 2) // %
  stockQty              Int       @default(0) @map("stock_qty")
  minStock              Int       @default(0) @map("min_stock")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")
  deletedById           String?   @map("deleted_by_id")
  createdById           String?   @map("created_by_id")
  updatedById           String?   @map("updated_by_id")

  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User?                  @relation("ItemCreatedBy", fields: [createdById], references: [id])
  updatedBy          User?                  @relation("ItemUpdatedBy", fields: [updatedById], references: [id])
  stockMovements     StockMovement[]
  purchaseItems      PurchaseInvoiceItem[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  salesItems         SalesInvoiceItem[]
  grnItems           GrnItem[]
  quotationItems     QuotationItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([category])
  @@index([name])
  @@index([sku])
  @@index([deletedAt])
  @@map("items")
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  itemId         String            @map("item_id")
  type           StockMovementType
  quantity       Int // positive for IN, negative for OUT
  referenceType  String?           @map("reference_type") // PurchaseInvoice, SalesInvoice, etc.
  referenceId    String?           @map("reference_id")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")
  deletedById    String?           @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([itemId])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("stock_movements")
}

// =============================================================================
// CONTACTS
// =============================================================================

model Supplier {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  name                String
  contactName         String?   @map("contact_name")
  email               String?
  phone               String?
  address             String?
  paymentTerms        String?   @map("payment_terms") // e.g. NET 30, 50% advance
  defaultPaymentTerms Int?      @map("default_payment_terms") // days for due date
  taxNumber           String?   @map("tax_number")
  creditLimit         Decimal?  @map("credit_limit") @db.Decimal(12, 2)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?   @map("deleted_by_id")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?             @relation("SupplierUpdatedBy", fields: [updatedById], references: [id])
  purchaseInvoices PurchaseInvoice[]
  purchaseOrders   PurchaseOrder[]
  grns             Grn[]

  @@index([organizationId])
  @@index([name])
  @@index([email])
  @@index([deletedAt])
  @@map("suppliers")
}

model Grn {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  supplierId       String    @map("supplier_id")
  purchaseOrderId  String?   @map("purchase_order_id")
  grnNo            String    @map("grn_no")
  receivedDate     DateTime  @map("received_date")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  items           GrnItem[]
  purchaseInvoices PurchaseInvoice[]

  @@unique([organizationId, grnNo])
  @@index([organizationId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([receivedDate])
  @@index([deletedAt])
  @@map("grns")
}

model GrnItem {
  id            String  @id @default(cuid())
  grnId         String  @map("grn_id")
  itemId        String  @map("item_id")
  quantity      Int
  purchasePrice Decimal @map("purchase_price") @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  grn  Grn  @relation(fields: [grnId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([grnId, itemId])
  @@index([grnId])
  @@index([itemId])
  @@map("grn_items")
}

model Client {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  name                String
  contactName         String?   @map("contact_name")
  email               String?
  phone               String?
  address             String?
  siteLocation        String?   @map("site_location")
  building            String?   @map("building")
  taxNumber           String?   @map("tax_number")
  defaultPaymentTerms String?   @map("default_payment_terms") // e.g. NET 30, 50% advance
  agreedDueDays       Int?      @map("agreed_due_days") // days for invoice due date
  creditLimit         Decimal?  @map("credit_limit") @db.Decimal(12, 2)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?   @map("deleted_by_id")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("ClientCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?          @relation("ClientUpdatedBy", fields: [updatedById], references: [id])
  quotations    Quotation[]
  salesOrders   SalesOrder[]
  salesInvoices SalesInvoice[]

  @@index([organizationId])
  @@index([name])
  @@index([email])
  @@index([deletedAt])
  @@map("clients")
}

// =============================================================================
// PURCHASES
// =============================================================================

model PurchaseRequest {
  id             String                @id @default(cuid())
  organizationId String                @map("organization_id")
  prNo           String                @map("pr_no")
  salesOrderId   String?               @map("sales_order_id")
  jobId          String?               @map("job_id")
  status         PurchaseRequestStatus @default(DRAFT) @map("status")
  notes          String?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")
  deletedById    String?               @map("deleted_by_id")
  createdById    String?               @map("created_by_id")
  approvedById   String?               @map("approved_by_id")
  approvedAt     DateTime?             @map("approved_at")
  approvalRemarks String?              @map("approval_remarks")

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder      SalesOrder?          @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  items           PurchaseRequestItem[]
  purchaseOrders  PurchaseOrder[]

  @@unique([organizationId, prNo])
  @@index([organizationId])
  @@index([salesOrderId])
  @@index([status])
  @@index([deletedAt])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                 String          @id @default(cuid())
  purchaseRequestId  String          @map("purchase_request_id")
  itemId             String          @map("item_id")
  quantity           Int
  fulfilledQuantity  Int             @default(0) @map("fulfilled_quantity")
  deletedAt          DateTime?       @map("deleted_at")
  deletedById        String?         @map("deleted_by_id")

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([purchaseRequestId, itemId])
  @@index([purchaseRequestId])
  @@index([itemId])
  @@index([deletedAt])
  @@map("purchase_request_items")
}

model PurchaseOrder {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  purchaseRequestId  String   @map("purchase_request_id")
  supplierId         String   @map("supplier_id")
  poNo               String   @map("po_no")
  orderDate          DateTime @map("order_date")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedById        String?  @map("deleted_by_id")
  createdById        String?  @map("created_by_id")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Restrict)
  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items          PurchaseOrderItem[]
  grns           Grn[]

  @@unique([organizationId, poNo])
  @@index([organizationId])
  @@index([purchaseRequestId])
  @@index([supplierId])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String   @map("purchase_order_id")
  itemId          String   @map("item_id")
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([purchaseOrderId, itemId])
  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_items")
}

model PurchaseInvoice {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  supplierId     String        @map("supplier_id")
  grnId          String?       @map("grn_id")
  invoiceNo      String        @map("invoice_no")
  invoiceDate    DateTime      @map("invoice_date")
  dueDate        DateTime?     @map("due_date")
  subtotal       Decimal       @map("subtotal") @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  currencyCode   String        @default("AED") @map("currency_code")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  deletedById    String?       @map("deleted_by_id")
  createdById    String?       @map("created_by_id")
  updatedById    String?       @map("updated_by_id")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  grn          Grn?                  @relation(fields: [grnId], references: [id], onDelete: SetNull)
  createdBy    User?                 @relation("PurchaseInvoiceCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?                 @relation("PurchaseInvoiceUpdatedBy", fields: [updatedById], references: [id])
  items        PurchaseInvoiceItem[]
  payments     SupplierPayment[]

  @@unique([organizationId, invoiceNo])
  @@index([grnId])
  @@index([organizationId])
  @@index([supplierId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([deletedAt])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String   @id @default(cuid())
  purchaseInvoiceId String   @map("purchase_invoice_id")
  itemId            String   @map("item_id")
  quantity          Int
  unitPrice         Decimal  @map("unit_price") @db.Decimal(12, 2)
  total             Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([purchaseInvoiceId, itemId])
  @@index([purchaseInvoiceId])
  @@index([itemId])
  @@map("purchase_invoice_items")
}

model SupplierPayment {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  purchaseInvoiceId String  @map("purchase_invoice_id")
  amount           Decimal  @db.Decimal(12, 2)
  paymentDate      DateTime @map("payment_date")
  method           String?
  reference        String?
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([purchaseInvoiceId])
  @@index([paymentDate])
  @@index([deletedAt])
  @@map("supplier_payments")
}

// =============================================================================
// SALES
// =============================================================================

model Quotation {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  clientId       String          @map("client_id")
  jobId          String          @map("job_id")
  quotationNo    String          @map("quotation_no")
  quotationDate  DateTime        @map("quotation_date")
  status         QuotationStatus @default(DRAFT)
  validUntil     DateTime?       @map("valid_until")
  notes          String?
  taxPercent     Decimal        @default(5) @map("tax_percent") @db.Decimal(5, 2)
  taxAmount      Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  taxRegistrationNo String?     @map("tax_registration_no")
  sealUrl        String?       @map("seal_url")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  deletedById    String?         @map("deleted_by_id")
  createdById    String?         @map("created_by_id")
  updatedById    String?         @map("updated_by_id")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  approvalRemarks String?        @map("approval_remarks")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy    User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?           @relation("QuotationUpdatedBy", fields: [updatedById], references: [id])
  items        QuotationItem[]
  salesOrder   SalesOrder?

  @@unique([organizationId, quotationNo])
  @@index([organizationId])
  @@index([clientId])
  @@index([jobId])
  @@index([status])
  @@index([deletedAt])
  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String  @map("quotation_id")
  itemId      String  @map("item_id")
  quantity    Int
  purchaseCost Decimal @map("purchase_cost") @db.Decimal(12, 2)
  margin      Decimal  @db.Decimal(5, 2) // %
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2) // selling price (cost + margin)
  total       Decimal  @db.Decimal(12, 2)
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([itemId])
  @@index([deletedAt])
  @@map("quotation_items")
}

model SalesOrder {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  quotationId    String   @unique @map("quotation_id")
  clientId       String   @map("client_id")
  jobId          String   @map("job_id")
  orderNo        String   @map("order_no")
  orderDate      DateTime @map("order_date")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?  @map("deleted_by_id")
  createdById    String?  @map("created_by_id")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation    Quotation      @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  items        SalesOrderItem[]
  salesInvoices SalesInvoice[]
  purchaseRequests PurchaseRequest[]

  @@unique([organizationId, orderNo])
  @@index([organizationId])
  @@index([quotationId])
  @@index([clientId])
  @@index([jobId])
  @@index([deletedAt])
  @@map("sales_orders")
}

model SalesOrderItem {
  id            String   @id @default(cuid())
  salesOrderId  String   @map("sales_order_id")
  itemId        String   @map("item_id")
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2) // inclusive (cost + margin)
  total         Decimal  @db.Decimal(12, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([salesOrderId])
  @@index([itemId])
  @@map("sales_order_items")
}

model SalesInvoice {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  salesOrderId   String        @map("sales_order_id")
  clientId       String        @map("client_id")
  jobId          String        @map("job_id")
  invoiceNo      String        @map("invoice_no")
  invoiceDate    DateTime      @map("invoice_date")
  dueDate        DateTime?     @map("due_date")
  subtotal       Decimal       @map("subtotal") @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  currencyCode   String        @default("AED") @map("currency_code")
  defaultTaxPercent Decimal    @default(5) @map("default_tax_percent") @db.Decimal(5, 2)
  pdfUrl         String?       @map("pdf_url")
  notes          String?
  taxRegistrationNo String?    @map("tax_registration_no")
  sealUrl        String?       @map("seal_url")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  deletedById    String?       @map("deleted_by_id")
  status         SalesInvoiceStatus @default(DRAFT) @map("status")
  approvedAt      DateTime?         @map("approved_at")
  approvalRemarks String?           @map("approval_remarks")
  createdById    String?           @map("created_by_id")
  updatedById    String?           @map("updated_by_id")
  approvedById   String?           @map("approved_by_id")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder         @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy    User?              @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?              @relation("SalesInvoiceUpdatedBy", fields: [updatedById], references: [id])
  approvedBy   User?              @relation("SalesInvoiceApprovedBy", fields: [approvedById], references: [id])
  items        SalesInvoiceItem[]
  payments     ClientPayment[]

  @@unique([organizationId, invoiceNo])
  @@index([organizationId])
  @@index([salesOrderId])
  @@index([clientId])
  @@index([jobId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([status])
  @@index([deletedAt])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id             String   @id @default(cuid())
  salesInvoiceId String   @map("sales_invoice_id")
  itemId         String   @map("item_id")
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  taxPercent     Decimal  @default(5) @map("tax_percent") @db.Decimal(5, 2)
  total          Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([salesInvoiceId])
  @@index([itemId])
  @@map("sales_invoice_items")
}

model ClientPayment {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  salesInvoiceId String   @map("sales_invoice_id")
  amount         Decimal  @db.Decimal(12, 2)
  paymentDate    DateTime @map("payment_date")
  paymentType    String?  @map("payment_type") // e.g. Bank Transfer, Cash, Card
  method         String?
  reference      String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([salesInvoiceId])
  @@index([paymentDate])
  @@index([deletedAt])
  @@map("client_payments")
}

// =============================================================================
// EXPENSES
// =============================================================================

model ExpenseCategory {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("expense_categories")
}

model Expense {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  categoryId     String    @map("category_id")
  amount         Decimal   @db.Decimal(12, 2)
  description    String?
  expenseDate    DateTime  @map("expense_date")
  isRecurring    Boolean   @default(false) @map("is_recurring")
   // Currency of this expense (e.g. AED, USD)
  currencyCode   String    @default("AED") @map("currency_code")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")
  createdById    String?   @map("created_by_id")
  updatedById    String?   @map("updated_by_id")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy    User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?           @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id])

  @@index([organizationId])
  @@index([categoryId])
  @@index([expenseDate])
  @@index([deletedAt])
  @@map("expenses")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model Document {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  fileName         String    @map("file_name")
  fileUrl          String    @map("file_url")
  mimeType         String    @map("mime_type")
  sizeBytes        Int       @map("size_bytes")
  documentableType String?   @map("documentable_type") // PurchaseInvoice, SalesInvoice, etc.
  documentableId   String?   @map("documentable_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")
  createdById      String?   @map("created_by_id")
  updatedById      String?   @map("updated_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?         @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])
  reportExports ReportExport[]

  @@index([organizationId])
  @@index([documentableType, documentableId])
  @@index([deletedAt])
  @@map("documents")
}

model ReportExport {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  documentId     String   @map("document_id")
  reportType     String   @map("report_type")
  format         String   @default("XLSX")
  metadata       Json?
  generatedById  String?  @map("generated_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  generatedBy  User?        @relation("ReportExportGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, expiresAt])
  @@index([documentId])
  @@map("report_exports")
}

// =============================================================================
// ACCOUNTING CORE (CHART OF ACCOUNTS + JOURNALS)
// =============================================================================

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum GlNormalSide {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  POSTED
  REVERSED
}

model GlAccount {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  code           String         @map("code")
  name           String         @map("name")
  type           GlAccountType @map("account_type")
  normalSide     GlNormalSide  @map("normal_side")
  isTaxAccount   Boolean        @default(false) @map("is_tax_account")

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  deletedById    String?       @map("deleted_by_id")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalLines   JournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("gl_accounts")
}

model JournalEntry {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  entryNo        String              @map("entry_no")
  entryDate      DateTime           @map("entry_date")
  memo           String?
  status         JournalEntryStatus @default(POSTED)

  referenceType  String?            @map("reference_type") // e.g. SalesInvoice, PurchaseInvoice, Expense
  referenceId    String?            @map("reference_id")

  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")
  deletedById    String?          @map("deleted_by_id")

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          JournalLine[]

  @@unique([organizationId, entryNo])
  @@index([organizationId, entryDate])
  @@index([referenceType, referenceId])
  @@index([deletedAt])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String       @map("journal_entry_id")
  accountId      String       @map("account_id")
  description    String?

  debitAmount    Decimal      @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount   Decimal      @default(0) @map("credit_amount") @db.Decimal(18, 2)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  deletedById    String?      @map("deleted_by_id")

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        GlAccount    @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([deletedAt])
  @@map("journal_lines")
}

// =============================================================================
// BANKING (BANK ACCOUNTS + STATEMENTS + RECONCILIATION)
// =============================================================================

enum BankReconciliationStatus {
  OPEN
  MATCHED
  CLOSED
}

model BankAccount {
  id                   String   @id @default(cuid())
  organizationId       String   @map("organization_id")
  name                 String   @map("name")
  bankName             String?  @map("bank_name")
  accountNumberMasked String?   @map("account_number_masked")
  currencyCode         String   @default("AED") @map("currency_code")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statements   BankStatement[]
  transactions BankTransaction[]
  reconciliations BankReconciliation[]

  @@index([organizationId])
  @@index([deletedAt])
  @@map("bank_accounts")
}

model BankStatement {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  bankAccountId  String   @map("bank_account_id")

  statementDate DateTime @map("statement_date")
  sourceFileUrl String? @map("source_file_url")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  transactions    BankTransaction[]
  reconciliations BankReconciliation[]

  @@index([organizationId])
  @@index([bankAccountId])
  @@index([statementDate])
  @@index([deletedAt])
  @@map("bank_statements")
}

model BankTransaction {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  bankStatementId String   @map("bank_statement_id")
  bankAccountId    String   @map("bank_account_id")

  transactionDate DateTime @map("transaction_date")
  reference       String?  @map("reference")
  description     String?  @map("description")
  amount          Decimal  @db.Decimal(12, 2)
  currencyCode    String   @default("AED") @map("currency_code")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankStatement BankStatement  @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  reconciliationItems BankReconciliationItem[]

  @@index([organizationId])
  @@index([bankStatementId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([deletedAt])
  @@map("bank_transactions")
}

model BankReconciliation {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  bankStatementId String   @map("bank_statement_id")
  bankAccountId    String   @map("bank_account_id")

  status     BankReconciliationStatus @default(OPEN) @map("status")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  deletedById String? @map("deleted_by_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankStatement BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  items BankReconciliationItem[]

  @@unique([organizationId, bankStatementId])
  @@index([organizationId])
  @@index([bankAccountId])
  @@index([deletedAt])
  @@map("bank_reconciliations")
}

model BankReconciliationItem {
  id                 String   @id @default(cuid())
  bankReconciliationId String @map("bank_reconciliation_id")
  bankTransactionId String   @unique @map("bank_transaction_id")

  // Store payment reference without hard FKs (keeps reconciliation flexible across modules)
  paymentType String @map("payment_type") // "ClientPayment" | "SupplierPayment"
  paymentId   String @map("payment_id")
  matchedAmount Decimal @db.Decimal(12, 2) @map("matched_amount")
  notes       String? @map("notes")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String? @map("deleted_by_id")

  bankReconciliation BankReconciliation @relation(fields: [bankReconciliationId], references: [id], onDelete: Cascade)
  bankTransaction    BankTransaction    @relation(fields: [bankTransactionId], references: [id], onDelete: Restrict)

  @@index([bankReconciliationId])
  @@index([deletedAt])
  @@map("bank_reconciliation_items")
}

// =============================================================================
// AUDIT LOG (all actions: login, logout, create, update, delete)
// =============================================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  action         String   // LOGIN, LOGOUT, CREATE_Supplier, UPDATE_Item, DELETE_Client, etc.
  entityType     String?  @map("entity_type") // Supplier, Client, Item, PurchaseInvoice, ...
  entityId      String?  @map("entity_id")
  metadata       Json?    // optional payload (e.g. { "invoiceNo": "INV-001" })
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
